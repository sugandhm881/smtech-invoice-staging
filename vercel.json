{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "crons": [
    {
      "path": "/send-daily-report?token=YOUR_CRON_SECRET_HERE",
      "schedule": "30 16 * * *"
    }
  ]
}